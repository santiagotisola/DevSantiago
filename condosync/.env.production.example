# ─── CondoSync Production Environment Variables ─────────────────────────────
# Copie para .env e preencha com valores reais
# NÃO faça commit deste arquivo com valores preenchidos!

# ─── Domínio ────────────────────────────────────────────────────────────────
DOMAIN=condosync.com.br

# ─── URL pública do app (front-end) ─────────────────────────────────────────
# Base dos links enviados por e-mail (aceite de convite de morador, reset de
# senha). DEVE ser a URL pública real com https — NUNCA localhost, senão os
# moradores recebem links que não abrem. A API recusa subir em produção se
# isto apontar para localhost.
FRONTEND_URL=https://condosync.app

# ─── Banco de Dados ─────────────────────────────────────────────────────────
DB_USER=condosync
DB_PASSWORD=           # Use uma senha forte (ex: openssl rand -base64 32)
DB_NAME=condosync

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=        # Use uma senha forte

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=            # openssl rand -base64 64
JWT_REFRESH_SECRET=    # openssl rand -base64 64

# ─── Email (Resend — gratuito até 100/dia) ──────────────────────────────────
# Criar conta: https://resend.com → API Keys → Create
RESEND_API_KEY=

# ─── Push Notifications (VAPID) ─────────────────────────────────────────────
# Gerar: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Sentry (Error Tracking — gratuito até 5K events/mês) ───────────────────
# Criar projeto: https://sentry.io → Projects → Create → Node.js
SENTRY_DSN=

# ─── ASAAS (Pagamentos PIX/Boleto) ──────────────────────────────────────────
# Sandbox: https://sandbox.asaas.com → Minha Conta → API
# Produção: https://www.asaas.com
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=   # Token customizado para validar webhooks
ASAAS_ENV=sandbox      # sandbox | production

# ─── WhatsApp (Evolution API — self-hosted, opcional) ────────────────────────
WHATSAPP_ENABLED=false
MONGODB_URI=
