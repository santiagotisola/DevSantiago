// ============================================================
// CondoSync - Prisma Schema
// Banco de dados relacional completo para gestão de condomínio
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMERAÇÕES
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  CONDOMINIUM_ADMIN
  SYNDIC
  DOORMAN
  RESIDENT
  SERVICE_PROVIDER
  COUNCIL_MEMBER
}

enum UnitStatus {
  OCCUPIED
  VACANT
  UNDER_RENOVATION
}

enum RenovationStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum VisitorStatus {
  PENDING
  AUTHORIZED
  DENIED
  INSIDE
  LEFT
}

enum ParcelStatus {
  RECEIVED
  NOTIFIED
  PICKED_UP
  RETURNED
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  CANCELED
}

enum ServiceOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum OccurrenceStatus {
  OPEN
  IN_ANALYSIS
  RESOLVED
  CLOSED
}

enum NotificationType {
  VISITOR
  PARCEL
  MAINTENANCE
  FINANCIAL
  COMMUNICATION
  RESERVATION
  OCCURRENCE
  ASSEMBLY
}

enum AssemblyStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum GatewayType {
  NONE
  ASAAS
  PJBANK
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  BICYCLE
  OTHER
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FULL_DAY
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS E PERMISSÕES
// ─────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  phone         String?
  cpf           String?  @unique
  avatarUrl     String?
  role          UserRole @default(RESIDENT)
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  condominiumUsers   CondominiumUser[]
  notifications      Notification[]
  sentMessages       ChatMessage[]    @relation("SentMessages")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  lostAndFoundItems  LostAndFound[] @relation("CreatedLostAndFound")
  ticketsCreated     Ticket[]       @relation("TicketCreator")
  ticketsAssigned    Ticket[]       @relation("TicketAssignee")
  ticketMessages     TicketMessage[] @relation("TicketMessages")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}

model Permission {
  id          String @id @default(uuid())
  module      String // ex: "portaria", "financeiro", "manutencao"
  action      String // ex: "create", "read", "update", "delete"
  description String?

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         UserRole
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String
  condominiumId String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id])

  @@unique([role, permissionId, condominiumId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// CONDOMÍNIO E ESTRUTURA
// ─────────────────────────────────────────────────────────────

model Condominium {
  id           String   @id @default(uuid())
  name         String
  cnpj         String?  @unique
  address      String
  city         String
  state        String
  zipCode      String
  phone        String?
  email        String?
  logoUrl      String?
  timezone     String   @default("America/Sao_Paulo")
  isActive     Boolean  @default(true)
  plan         String   @default("basic") // basic, professional, enterprise
  maxUnits     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  units              Unit[]
  condominiumUsers   CondominiumUser[]
  employees          Employee[]
  serviceProviders   ServiceProvider[]
  commonAreas        CommonArea[]
  financialAccounts  FinancialAccount[]
  announcements      Announcement[]
  occurrences        Occurrence[]
  rolePermissions    RolePermission[]
  auditLogs          AuditLog[]
  maintenanceSchedules MaintenanceSchedule[]
  contracts          Contract[]
  polls              Poll[]
  assemblies         Assembly[]
  lostAndFoundItems  LostAndFound[]
  documents          CondominiumDocument[]

  @@map("condominiums")
}

model CondominiumUser {
  id            String      @id @default(uuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  role          UserRole
  isActive      Boolean     @default(true)
  joinedAt      DateTime    @default(now())

  unit          Unit?       @relation(fields: [unitId], references: [id])
  unitId        String?

  @@unique([userId, condominiumId])
  @@map("condominium_users")
}

model Unit {
  id            String     @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  identifier    String     // ex: "Casa 01", "Lote 15"
  block         String?
  street        String?    // endereço / rua da unidade
  floor         String?    // andar
  type          String?    // tipo: apartamento, casa, loja, etc.
  area          Float?
  bedrooms      Int?
  status        UnitStatus @default(OCCUPIED)
  fraction      Decimal    @default(1.0) @db.Decimal(8,6) // fração ideal para rateio
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relações
  residents     CondominiumUser[]
  vehicles      Vehicle[]
  visitors      Visitor[]         @relation("UnitVisitors")
  parcels       Parcel[]
  charges       Charge[]
  serviceOrders ServiceOrder[]
  dependents    Dependent[]
  pets          Pet[]
  renovations   Renovation[]

  @@unique([condominiumId, identifier, block])
  @@map("units")
}

model Dependent {
  id         String   @id @default(uuid())
  unit       Unit     @relation(fields: [unitId], references: [id])
  unitId     String
  name       String
  relationship String  // filho, cônjuge, pai, etc.
  birthDate  DateTime?
  cpf        String?
  photoUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("dependents")
}

model Vehicle {
  id           String      @id @default(uuid())
  unit         Unit        @relation(fields: [unitId], references: [id])
  unitId       String
  plate        String      @unique
  brand        String
  model        String
  color        String
  year         Int?
  type         VehicleType @default(CAR)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  accessLogs   VehicleAccessLog[]

  @@map("vehicles")
}

model Employee {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String
  cpf           String
  role          String      // porteiro, zelador, jardineiro, etc.
  phone         String?
  email         String?
  shift         ShiftType
  admissionDate DateTime
  salaryAmount  Decimal?   @db.Decimal(10,2)
  isActive      Boolean     @default(true)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("employees")
}

model ServiceProvider {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String
  cnpj          String?
  cpf           String?
  serviceType   String      // encanador, eletricista, pintor, etc.
  phone         String
  email         String?
  isApproved    Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  visitors      Visitor[]
  serviceOrders ServiceOrder[]
  contracts     Contract[]

  @@map("service_providers")
}

// ─────────────────────────────────────────────────────────────
// PORTARIA E CONTROLE DE ACESSO
// ─────────────────────────────────────────────────────────────

model Visitor {
  id                String        @id @default(uuid())
  unit              Unit          @relation("UnitVisitors", fields: [unitId], references: [id])
  unitId            String
  name              String
  document          String?
  documentType      String?       // CPF, RG, CNH
  phone             String?
  photoUrl          String?
  company           String?
  reason            String?
  preAuthorizedBy   String?       // ID do morador que autorizou
  status            VisitorStatus @default(PENDING)
  scheduledAt       DateTime?
  entryAt           DateTime?
  exitAt            DateTime?
  registeredBy      String?       // ID do porteiro
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?

  @@map("visitors")
}

model VehicleAccessLog {
  id          String   @id @default(uuid())
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId   String?
  plate       String   // mesmo para não cadastrados
  unitId      String?
  isResident  Boolean  @default(false)
  entryAt     DateTime @default(now())
  exitAt      DateTime?
  notes       String?
  registeredBy String?

  @@map("vehicle_access_logs")
}

model Parcel {
  id                  String       @id @default(uuid())
  unit                Unit         @relation(fields: [unitId], references: [id])
  unitId              String
  senderName          String?
  carrier             String?
  trackingCode        String?
  photoUrl            String?
  storageLocation     String?
  // Dados do entregador (Lei 11.442/07 + LGPD Art. 7º IX)
  deliveryPersonName  String?      // Nome completo do entregador
  deliveryPersonDoc   String?      // CPF ou RG (apenas números)
  vehiclePlate        String?      // Placa do veículo (RNTRC/ANTT)
  // Controle de avaria (Art. 754 Código Civil)
  hasPackageDamage    Boolean      @default(false)
  status              ParcelStatus @default(RECEIVED)
  receivedAt          DateTime     @default(now())
  notifiedAt          DateTime?
  pickedUpAt          DateTime?
  pickedUpBy          String?      // nome de quem retirou
  pickupSignature     String?      // assinatura digital ou PIN
  notes               String?
  registeredBy        String?

  @@map("parcels")
}

// ─────────────────────────────────────────────────────────────
// COMUNICAÇÃO
// ─────────────────────────────────────────────────────────────

model Announcement {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  title         String
  content       String
  authorId      String
  isPinned      Boolean     @default(false)
  isOfficial    Boolean     @default(false)
  attachments   String[]
  targetRoles   UserRole[]
  publishedAt   DateTime    @default(now())
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("announcements")
}

model Notification {
  id        String           @id @default(uuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model ChatConversation {
  id            String   @id @default(uuid())
  condominiumId String
  unitId        String?
  subject       String?
  participants  String[] // array de userIds
  isOpen        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])
  conversationId String
  sender         User             @relation("SentMessages", fields: [senderId], references: [id])
  senderId       String
  content        String
  attachments    String[]
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@map("chat_messages")
}

model Poll {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  title         String
  description   String?
  options       Json        // [{id, text, votes}]
  allowMultiple Boolean     @default(false)
  isAnonymous   Boolean     @default(false)
  startsAt      DateTime    @default(now())
  endsAt        DateTime
  createdBy     String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id         String   @id @default(uuid())
  poll       Poll     @relation(fields: [pollId], references: [id])
  pollId     String
  userId     String
  optionIds  String[] // opções escolhidas
  votedAt    DateTime @default(now())

  @@unique([pollId, userId])
  @@map("poll_votes")
}

model Occurrence {
  id            String           @id @default(uuid())
  condominium   Condominium      @relation(fields: [condominiumId], references: [id])
  condominiumId String
  reportedBy    String
  title         String
  description   String
  category      String           // segurança, barulho, vandalismo, etc.
  location      String?
  photoUrls     String[]
  status        OccurrenceStatus @default(OPEN)
  priority      ServiceOrderPriority @default(MEDIUM)
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("occurrences")
}

// ─────────────────────────────────────────────────────────────
// FINANCEIRO
// ─────────────────────────────────────────────────────────────

model FinancialAccount {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String      // Conta principal, fundo reserva, etc.
  bankName      String?
  agency        String?
  accountNumber String?
  balance       Decimal     @default(0) @db.Decimal(12,2)
  isActive      Boolean     @default(true)
  
  // Gateway config
  gatewayType   GatewayType @default(NONE)
  gatewayKey    String?     // API Key or Token
  gatewayConfig Json?       // walletId, common settings, etc.

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  transactions FinancialTransaction[]
  charges      Charge[]

  @@map("financial_accounts")
}

model FinancialCategory {
  id          String                   @id @default(uuid())
  condominiumId String
  name        String
  type        FinancialTransactionType
  description String?
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())

  transactions FinancialTransaction[]
  charges      Charge[]

  @@map("financial_categories")
}

model FinancialTransaction {
  id               String                   @id @default(uuid())
  account          FinancialAccount         @relation(fields: [accountId], references: [id])
  accountId        String
  category         FinancialCategory?       @relation(fields: [categoryId], references: [id])
  categoryId       String?
  type             FinancialTransactionType
  amount           Decimal  @db.Decimal(12,2)
  description      String
  dueDate          DateTime
  paidAt           DateTime?
  referenceMonth   String?                  // "2025-01"
  receiptUrl       String?
  notes            String?
  createdBy        String
  chargeId         String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@map("financial_transactions")
}

model Charge {
  id            String            @id @default(uuid())
  unit          Unit              @relation(fields: [unitId], references: [id])
  unitId        String
  account       FinancialAccount  @relation(fields: [accountId], references: [id])
  accountId     String
  category      FinancialCategory? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  description   String
  amount        Decimal  @db.Decimal(12,2)
  dueDate       DateTime
  paidAt        DateTime?
  paidAmount    Decimal? @db.Decimal(12,2)
  status        ChargeStatus      @default(PENDING)
  referenceMonth String?
  
  // Gateway metadata
  gatewayId     String?
  gatewayStatus String?
  pixQrCode     String?     @db.Text
  pixCopyPaste  String?     @db.Text
  paymentLink   String?     @db.Text

  boletoUrl     String?
  boletoCode    String?
  penaltyAmount Decimal           @default(0) @db.Decimal(12,2)
  interestRate  Decimal           @default(0) @db.Decimal(5,4) // % a.m.
  createdBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("charges")
}

// ─────────────────────────────────────────────────────────────
// MANUTENÇÃO
// ─────────────────────────────────────────────────────────────

model ServiceOrder {
  id              String               @id @default(uuid())
  unit            Unit?                @relation(fields: [unitId], references: [id])
  unitId          String?
  condominiumId   String
  requestedBy     String
  assignedTo      String?
  serviceProvider ServiceProvider?     @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?
  title           String
  description     String
  category        String               // elétrica, hidráulica, limpeza, etc.
  location        String?
  priority        ServiceOrderPriority @default(MEDIUM)
  status          ServiceOrderStatus   @default(OPEN)
  photoUrls       String[]
  estimatedCost   Decimal? @db.Decimal(10,2)
  finalCost       Decimal? @db.Decimal(10,2)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  resolution      String?
  rating          Int?                 // 1-5
  feedback        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  checklistItems    ServiceOrderChecklist[]

  @@map("service_orders")
}

model ServiceOrderChecklist {
  id             String       @id @default(uuid())
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  serviceOrderId String
  item           String
  isDone         Boolean      @default(false)
  doneAt         DateTime?
  notes          String?

  @@map("service_order_checklists")
}

model MaintenanceSchedule {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  title         String
  description   String?
  category      String
  location      String
  frequency     String      // diário, semanal, mensal, anual
  nextDueDate   DateTime
  lastDoneDate  DateTime?
  estimatedCost Decimal? @db.Decimal(10,2)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("maintenance_schedules")
}

model Contract {
  id              String          @id @default(uuid())
  condominium     Condominium     @relation(fields: [condominiumId], references: [id])
  condominiumId   String
  serviceProvider ServiceProvider @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String
  title           String
  description     String?
  value           Decimal  @db.Decimal(12,2)
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean         @default(true)
  documentUrl     String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("contracts")
}

// ─────────────────────────────────────────────────────────────
// ÁREAS COMUNS
// ─────────────────────────────────────────────────────────────

model CommonArea {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String      // Salão de festas, quadra, etc.
  description   String?
  capacity      Int?
  rules         String?
  photoUrls     String[]
  isActive      Boolean     @default(true)
  requiresApproval Boolean  @default(false)
  maxDaysAdvance Int        @default(30)
  openTime      String?     // "08:00"
  closeTime     String?     // "22:00"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  reservations  Reservation[]
  blockedPeriods AreaBlockedPeriod[]

  @@map("common_areas")
}

model Reservation {
  id           String            @id @default(uuid())
  commonArea   CommonArea        @relation(fields: [commonAreaId], references: [id])
  commonAreaId String
  unitId       String
  requestedBy  String
  title        String?
  startDate    DateTime
  endDate      DateTime
  guestCount   Int?
  status       ReservationStatus @default(PENDING)
  approvedBy   String?
  canceledBy   String?
  cancelReason String?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("reservations")
}

model AreaBlockedPeriod {
  id           String     @id @default(uuid())
  commonArea   CommonArea @relation(fields: [commonAreaId], references: [id])
  commonAreaId String
  reason       String
  startDate    DateTime
  endDate      DateTime
  createdBy    String
  createdAt    DateTime   @default(now())

  @@map("area_blocked_periods")
}

// ─────────────────────────────────────────────────────────────
// ASSEMBLEIAS
// ─────────────────────────────────────────────────────────────

model Assembly {
  id             String         @id @default(uuid())
  condominium    Condominium    @relation(fields: [condominiumId], references: [id])
  condominiumId  String
  title          String
  description    String?
  meetingUrl     String?        // Link Zoom/Meet
  scheduledAt    DateTime
  startedAt      DateTime?
  finishedAt     DateTime?
  minutesUrl     String?        // PDF da ata
  status         AssemblyStatus @default(SCHEDULED)
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  votingItems    AssemblyVotingItem[]
  attendees      AssemblyAttendee[]

  @@map("assemblies")
}

model AssemblyVotingItem {
  id          String   @id @default(uuid())
  assembly    Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  assemblyId  String
  title       String
  description String?
  options     Json     // [{id, text}]
  
  votes       AssemblyVote[]

  @@map("assembly_voting_items")
}

model AssemblyVote {
  id           String             @id @default(uuid())
  votingItem   AssemblyVotingItem @relation(fields: [votingItemId], references: [id], onDelete: Cascade)
  votingItemId String
  userId       String
  optionId     String             // ID da opção escolhida do JSON
  votedAt      DateTime           @default(now())

  @@unique([votingItemId, userId])
  @@map("assembly_votes")
}

model AssemblyAttendee {
  id          String   @id @default(uuid())
  assembly    Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  assemblyId  String
  userId      String
  joinedAt    DateTime @default(now())
  leftAt      DateTime?

  @@unique([assemblyId, userId])
  @@map("assembly_attendees")
}

// ─────────────────────────────────────────────────────────────
// SEGURANÇA E AUDITORIA
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(uuid())
  user          User?       @relation(fields: [userId], references: [id])
  userId        String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id])
  condominiumId String?
  action        String      // CREATE, UPDATE, DELETE, LOGIN, etc.
  module        String      // portaria, financeiro, etc.
  entityType    String?     // Visitor, Parcel, etc.
  entityId      String?
  description   String
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  @@map("audit_logs")
}
model FinalizedAssembly {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime @default(now())
  minutesUrl  String?
  condominiumId String
  
  @@map("finalized_assemblies")
}

model Pet {
  id            String      @id @default(uuid())
  name          String
  type          String      // Cachorro, Gato, Pássaro, etc.
  breed         String?
  size          String?     // Pequeno, Médio, Grande
  gender        String?     // Macho, Fêmea
  birthDate     DateTime?
  color         String?
  photoUrl      String?
  weight        Float?
  lastVaccination DateTime?
  isActive      Boolean     @default(true)
  notes         String?
  
  unit          Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId        String
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("pets")
}
enum LostAndFoundStatus {
  LOST
  FOUND
  RETURNED
  DISCARDED
}

model LostAndFound {
  id            String             @id @default(uuid())
  title         String
  description   String?
  category      String             // Eletrônico, Chaves, Vestuário, etc.
  place         String?            // Onde foi encontrado/perdido
  status        LostAndFoundStatus @default(FOUND)
  photoUrl      String?
  foundDate     DateTime?
  lostDate      DateTime?
  returnedAt    DateTime?
  returnedTo    String?            // Nome de quem retirou
  
  condominium   Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  
  createdBy     User               @relation("CreatedLostAndFound", fields: [createdById], references: [id])
  createdById   String
  
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("lost_and_found")
}

// ─────────────────────────────────────────────────────────────
// DOCUMENTOS DO CONDOMÍNIO
// ─────────────────────────────────────────────────────────────

model CondominiumDocument {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  title         String
  description   String?
  category      String      // ata, convenção, regulamento, boleto, comunicado, outro
  fileName      String      // nome original do arquivo
  storedName    String      // nome UUID usado no disco
  filePath      String      // caminho completo
  fileSize      Int
  mimeType      String
  uploadedBy    String      // userId de quem fez upload
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("condominium_documents")
}

// ─────────────────────────────────────────────────────────────
// OBRAS E REFORÇAS
// ─────────────────────────────────────────────────────────────

model Renovation {
  id            String           @id @default(uuid())
  unit          Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId        String
  condominiumId String
  description   String
  type          String           // pintura, hidráulica, elétrica, estrutural, outro
  startDate     DateTime
  endDate       DateTime?
  status        RenovationStatus @default(PENDING)
  approvedBy    String?          // userId
  approvedAt    DateTime?
  rejectedReason String?
  notes         String?
  createdBy     String           // userId do morador
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  authorizedProviders RenovationProvider[]

  @@map("renovations")
}

model RenovationProvider {
  id           String     @id @default(uuid())
  renovation   Renovation @relation(fields: [renovationId], references: [id], onDelete: Cascade)
  renovationId String
  name         String
  serviceType  String
  document     String?    // CPF ou CNPJ
  phone        String?
  company      String?
  createdAt    DateTime   @default(now())

  @@map("renovation_providers")
}

// ─── Controle de Estoque ── MEL-07 ───────────────────────────────────────────

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model StockItem {
  id              String          @id @default(uuid())
  condominiumId   String
  name            String
  description     String?
  category        String          // limpeza, manutenção, segurança, escritório, outro
  unit            String          // unidade de medida: un, kg, L, m, etc.
  quantity        Float           @default(0)
  minQuantity     Float           @default(0)  // estoque mínimo para alerta
  location        String?         // ex: "Almoxarifado", "Depósito 2"
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  movements       StockMovement[]

  @@map("stock_items")
}

model StockMovement {
  id          String            @id @default(uuid())
  item        StockItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  type        StockMovementType
  quantity    Float
  reason      String?
  performedBy String
  createdAt   DateTime          @default(now())

  @@map("stock_movements")
}

// ─── Tickets / Mensagens individuais ── MEL-06 ────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketCategory {
  manutencao
  financeiro
  barulho
  seguranca
  outro
}

model Ticket {
  id            String          @id @default(uuid())
  condominiumId String
  title         String
  category      TicketCategory  @default(outro)
  priority      TicketPriority  @default(LOW)
  status        TicketStatus    @default(OPEN)
  createdById   String
  createdBy     User            @relation("TicketCreator", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  messages      TicketMessage[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  senderId  String
  sender    User     @relation("TicketMessages", fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

// ─── Galeria de Fotos ── MEL-10 ───────────────────────────────────────────────

model Photo {
  id            String   @id @default(uuid())
  condominiumId String
  title         String
  description   String?
  category      String   // areas-comuns, eventos, obras, outro
  fileName      String
  storedName    String
  filePath      String
  fileSize      Int
  mimeType      String
  uploadedBy    String
  createdAt     DateTime @default(now())

  @@map("photos")
}
