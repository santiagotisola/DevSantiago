# Database
DATABASE_URL="postgresql://condosync:condosync123@localhost:5432/condosync?schema=public"

# JWT
JWT_SECRET="condosync-super-secret-jwt-key-with-at-least-32-chars"
JWT_REFRESH_SECRET="condosync-super-secret-refresh-key-with-at-least-32-chars"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3333
NODE_ENV="development"

# Redis
REDIS_URL="redis://localhost:6379"

# CORS
CORS_ORIGINS="http://localhost:5173"

# Bcrypt
BCRYPT_ROUNDS=12

# SMTP (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@condosync.com.br"
