# ────────────────────────────────────────────────────────────
# CondoSync — variaveis lidas pelo docker-compose.yml (DEV LOCAL)
# Copiar para .env e preencher. cp .env.example .env
#
# Para produção, use docker-compose.prod.yml com seu .env de prod.
# ────────────────────────────────────────────────────────────

# ── Postgres ────────────────────────────────────────────────
POSTGRES_USER=condosync
POSTGRES_PASSWORD=condosync
POSTGRES_DB=condosync

# ── Redis (senha obrigatoria) ───────────────────────────────
REDIS_PASSWORD=condosync
