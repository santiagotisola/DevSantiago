# ────────────────────────────────────────────────────────────
# CondoSync — variaveis lidas pelo docker-compose.yml
# Copiar para .env e preencher.  cp .env.example .env
# ────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Postgres ────────────────────────────────────────────────
POSTGRES_USER=condosync
POSTGRES_PASSWORD=trocar-por-senha-forte
POSTGRES_DB=condosync

# ── Redis (senha obrigatoria) ───────────────────────────────
REDIS_PASSWORD=trocar-por-senha-forte

# ── JWT (32+ chars cada, DIFERENTES entre si) ───────────────
# Gerar com:  openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:80,http://localhost

# ── Bcrypt ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── OpenAI (opcional) ───────────────────────────────────────
OPENAI_API_KEY=

# ── Asaas webhook (obrigatorio para usar /webhooks/asaas) ───
ASAAS_WEBHOOK_TOKEN=

# ── SMTP (default: mailpit local) ───────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=condosync
SMTP_PASS=condosync
SMTP_FROM=CondoSync <noreply@condosync.com.br>
