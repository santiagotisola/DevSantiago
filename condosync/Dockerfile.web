# ─── Stage 1: Builder ─────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Copiar package.json da web
COPY apps/web/package.json apps/web/package-lock.json ./

# Instalar dependências
RUN npm ci

# Copiar código-fonte da web
COPY apps/web/ ./

# Build de produção com Vite
RUN npm run build

# ─── Stage 2: Production (nginx) ──────────────────────────────────────────────
FROM nginx:1.27-alpine AS production

# Remover configuração padrão do nginx
RUN rm /etc/nginx/conf.d/default.conf

# Copiar configuração nginx template
COPY apps/web/nginx.conf.template /etc/nginx/templates/default.conf.template

# Copiar build do Vite da stage anterior
COPY --from=builder /app/dist /usr/share/nginx/html

# Variável de ambiente para API_URL (será substituída em tempo de execução)
ENV API_URL=https://devsantiago-production.up.railway.app

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
