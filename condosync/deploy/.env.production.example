# =============================================================================
# CondoSync — .env.production.example
# Copie para .env.production (UM NIVEL ACIMA: condosync/.env.production)
# e preencha. NUNCA commit.
# =============================================================================

# ── Dominio + TLS ────────────────────────────────────────────────────────────
DOMAIN=condosync.exemplo.com.br
ACME_EMAIL=ops@exemplo.com.br
CORS_ORIGINS=https://condosync.exemplo.com.br

# ── Registry de imagens ─────────────────────────────────────────────────────
# Onde estao publicadas: condosync-api:<tag> e condosync-web:<tag>
# Ex: ghcr.io/sua-org   |   registry.hostinger.com/sua-org   |   docker.io/seuuser
IMAGE_REGISTRY=ghcr.io/sua-org
IMAGE_TAG_BLUE=v1.0.0
IMAGE_TAG_GREEN=v1.0.0

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=condosync
POSTGRES_PASSWORD=                # openssl rand -base64 32 | tr -d '/+=' | head -c 40
POSTGRES_DB=condosync

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                   # openssl rand -base64 32 | tr -d '/+=' | head -c 40

# ── JWT (devem ser DIFERENTES entre si) ─────────────────────────────────────
JWT_SECRET=                       # openssl rand -base64 64 | tr -d '/+=' | head -c 64
JWT_REFRESH_SECRET=               # openssl rand -base64 64 | tr -d '/+=' | head -c 64
JWT_SECRET_PREVIOUS=              # vazio em primeira instalacao; preencher em rotacao
JWT_REFRESH_SECRET_PREVIOUS=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── App encryption (gatewayKey, fields-level) ───────────────────────────────
APP_ENCRYPTION_KEY=               # openssl rand -base64 32  (exatos 32 bytes apos decode)
APP_ENCRYPTION_KEY_PREVIOUS=

# ── Observabilidade (opcional, mas recomendado) ─────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER_ARG=0.1

# ── Pagamento Asaas ─────────────────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CondoSync <noreply@condosync.com.br>

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
