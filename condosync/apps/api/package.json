{
  "name": "@condosync/api",
  "version": "1.0.0",
  "description": "CondoSync API - Backend REST",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "encrypt:gateway-keys": "ts-node prisma/encrypt-gateway-keys.ts",
    "cleanup:orphans": "ts-node prisma/cleanup-condominium-orphans.ts",
    "redrive:webhooks": "ts-node scripts/redrive-webhooks.ts",
    "partitions:create": "ts-node scripts/partition-maintenance.ts create",
    "partitions:archive": "ts-node scripts/partition-maintenance.ts archive",
    "partitions:check": "ts-node scripts/partition-maintenance.ts check",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:it": "vitest run --config vitest.it.config.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "prom-client": "^15.1.3",
    "@sentry/node": "^10.47.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@types/pdfkit": "^0.17.5",
    "axios": "^1.13.6",
    "opossum": "^8.1.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.4",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.10.0",
    "socket.io": "^4.7.4",
    "@socket.io/redis-adapter": "^8.3.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xss": "^1.0.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^6.4.23",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@testcontainers/postgresql": "^10.13.0",
    "testcontainers": "^10.13.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prisma": "^5.10.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  }
}
