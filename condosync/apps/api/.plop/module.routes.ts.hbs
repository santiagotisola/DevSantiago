import { authenticate, authorize, MANAGEMENT_ROLES } from "../../middleware/auth";
import { {{camelCase name}}Controller } from "./{{name}}.controller";

const router = Router();
router.use(authenticate);

router.get("/condominium/:condominiumId", {{camelCase name}}Controller.list);
