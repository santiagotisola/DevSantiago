router.get("/:id", {{camelCase name}}Controller.getById);
router.patch("/:id", authorize(...MANAGEMENT_ROLES), {{camelCase name}}Controller.update);
router.delete("/:id", authorize(...MANAGEMENT_ROLES), {{camelCase name}}Controller.delete);

export default router;
