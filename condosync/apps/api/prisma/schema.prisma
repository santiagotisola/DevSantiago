// ============================================================
// CondoSync - Prisma Schema
// Banco de dados relacional completo para gestão de condomínio
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMERAÇÕES
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  CONDOMINIUM_ADMIN
  SYNDIC
  DOORMAN
  RESIDENT
  SERVICE_PROVIDER
  COUNCIL_MEMBER
}

enum UnitStatus {
  OCCUPIED
  VACANT
  UNDER_RENOVATION
  BLOCKED
}

enum RenovationStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum VisitorStatus {
  PENDING
  AUTHORIZED
  DENIED
  INSIDE
  LEFT
}

enum ParcelStatus {
  RECEIVED
  NOTIFIED
  PICKED_UP
  RETURNED
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  CANCELED
}

enum ServiceOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum OccurrenceStatus {
  OPEN
  IN_ANALYSIS
  RESOLVED
  CLOSED
}

enum NotificationType {
  VISITOR
  PARCEL
  MAINTENANCE
  FINANCIAL
  COMMUNICATION
  RESERVATION
  OCCURRENCE
  ASSEMBLY
  PANIC
  VISITOR_ARRIVAL
  PARCEL_RECEIVED
  MAINTENANCE_UPDATE
  PAYMENT_DUE
  PAYMENT_CONFIRMED
  ANNOUNCEMENT
  TICKET_REPLY
  ASSEMBLY_SCHEDULED
  PANIC_ALERT
  RESERVATION_STATUS
  GENERAL
}

enum AssemblyStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum GatewayType {
  NONE
  ASAAS
  PJBANK
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  BICYCLE
  OTHER
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FULL_DAY
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS E PERMISSÕES
// ─────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  name                 String
  phone                String?
  cpf                  String?   @unique
  avatarUrl            String?
  role                 UserRole  @default(RESIDENT)
  isActive             Boolean   @default(true)
  emailVerified        Boolean   @default(false)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  // Códigos de backup (hash sha256, um uso cada). Array Json estilo
  // [{"hash":"...", "usedAt": null}].
  twoFactorBackupCodes Json?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relações
  condominiumUsers    CondominiumUser[]
  notifications       Notification[]
  notificationPrefs   NotificationPreference[]
  sentMessages        ChatMessage[]            @relation("SentMessages")
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  passwordResets      PasswordReset[]
  invitationsCreated  Invitation[]             @relation("InvitationCreator")
  invitationsAccepted Invitation[]             @relation("InvitationAcceptedBy")
  pushSubscriptions   PushSubscription[]
  webAuthnCredentials WebAuthnCredential[]
  termsAcceptances    TermsAcceptance[]
  lostAndFoundItems   LostAndFound[]           @relation("CreatedLostAndFound")
  ticketsCreated      Ticket[]                 @relation("TicketCreator")
  ticketsAssigned     Ticket[]                 @relation("TicketAssignee")
  ticketMessages      TicketMessage[]          @relation("TicketMessages")
  employee            Employee?

  // NOVO: Marketplace
  productRequests MarketplaceProductRequest[]
  chatMessages    MarketplaceChatMessage[]
  productReviews  MarketplaceProductReview[]
  favorites       ResidentFavorite[]
  loyaltyPoints   LoyaltyPoints?
  purchaseHistory PurchaseHistory[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  // Metadata pra tela "Meus dispositivos" (Q2.4). Opcionais pra não
  // quebrar tokens antigos.
  ipAddress  String?
  userAgent  String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}

model Permission {
  id          String  @id @default(uuid())
  module      String // ex: "portaria", "financeiro", "manutencao"
  action      String // ex: "create", "read", "update", "delete"
  description String?

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id            String       @id @default(uuid())
  role          UserRole
  permission    Permission   @relation(fields: [permissionId], references: [id])
  permissionId  String
  condominiumId String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id])

  @@unique([role, permissionId, condominiumId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// CONDOMÍNIO E ESTRUTURA
// ─────────────────────────────────────────────────────────────

model Condominium {
  id           String   @id @default(uuid())
  name         String
  cnpj         String?  @unique
  address      String
  city         String
  state        String
  zipCode      String
  phone        String?
  email        String?
  logoUrl      String?
  heroImageUrl String?
  timezone     String   @default("America/Sao_Paulo")
  isActive     Boolean  @default(true)
  plan         String   @default("basic") // basic, professional, enterprise
  maxUnits     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  units                   Unit[]
  condominiumUsers        CondominiumUser[]
  employees               Employee[]
  serviceProviders        ServiceProvider[]
  commonAreas             CommonArea[]
  financialAccounts       FinancialAccount[]
  announcements           Announcement[]
  occurrences             Occurrence[]
  rolePermissions         RolePermission[]
  auditLogs               AuditLog[]
  maintenanceSchedules    MaintenanceSchedule[]
  contracts               Contract[]
  polls                   Poll[]
  assemblies              Assembly[]
  lostAndFoundItems       LostAndFound[]
  documents               CondominiumDocument[]
  panicAlerts             PanicAlert[]
  visitorRecurrences      VisitorRecurrence[]
  // C4 — back-relations adicionadas pela conversão de
  // condominiumId String → FK em 13 modelos.
  chatConversations       ChatConversation[]
  financialCategories     FinancialCategory[]
  serviceOrders           ServiceOrder[]
  finalizedAssemblies     FinalizedAssembly[]
  renovations             Renovation[]
  stockItems              StockItem[]
  tickets                 Ticket[]
  photos                  Photo[]
  condominiumContracts    CondominiumContract[]
  fines                   Fine[]
  collectionRules         CollectionRule[]
  digitalSignageScreens   DigitalSignageScreen[]
  invitations             Invitation[]
  // Marketplace / módulos adicionais (origin/main)
  marketplacePartners     MarketplacePartner[]            @relation(name: "PartnerToCondominium")
  marketplaceOffers       MarketplaceOffer[]
  marketplacePartnerLinks CondominiumMarketplacePartner[]
  marketplaceProducts     MarketplaceProduct[]
  marketplaceCategories   MarketplaceCategory[]
  productRequests         MarketplaceProductRequest[]
  purchaseHistory         PurchaseHistory[]               @relation("PurchaseHistoryCondominium")
  movingSchedules         MovingSchedule[]
  keyControls             KeyControl[]
  cameras                 Camera[]
  notifications           Notification[]

  @@map("condominiums")
}

model CondominiumUser {
  id            String      @id @default(uuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  role          UserRole
  isActive      Boolean     @default(true)
  joinedAt      DateTime    @default(now())

  unit   Unit?   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitId String?

  @@unique([userId, condominiumId])
  @@map("condominium_users")
}

model Unit {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  identifier    String // ex: "Casa 01", "Lote 15"
  block         String?
  street        String? // endereço / rua da unidade
  floor         String? // andar
  type          String? // tipo: apartamento, casa, loja, etc.
  area          Float?
  bedrooms      Int?
  status        UnitStatus  @default(OCCUPIED)
  fraction      Decimal     @default(1.0) @db.Decimal(8, 6) // fração ideal para rateio
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relações
  residents          CondominiumUser[]
  vehicles           Vehicle[]
  visitors           Visitor[]           @relation("UnitVisitors")
  parcels            Parcel[]
  charges            Charge[]
  serviceOrders      ServiceOrder[]
  dependents         Dependent[]
  pets               Pet[]
  renovations        Renovation[]
  visitorRecurrences VisitorRecurrence[]
  visitorQRCodes     VisitorQRCode[]
  invitations        Invitation[]
  movingSchedules    MovingSchedule[]

  @@unique([condominiumId, identifier, block])
  @@map("units")
}

model Dependent {
  id           String    @id @default(uuid())
  unit         Unit      @relation(fields: [unitId], references: [id])
  unitId       String
  name         String
  relationship String // filho, cônjuge, pai, etc.
  birthDate    DateTime?
  cpf          String?
  photoUrl     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@map("dependents")
}

model Vehicle {
  id        String      @id @default(uuid())
  unit      Unit        @relation(fields: [unitId], references: [id])
  unitId    String
  plate     String      @unique
  brand     String
  model     String
  color     String
  year      Int?
  type      VehicleType @default(CAR)
  photoUrl  String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  accessLogs VehicleAccessLog[]

  @@map("vehicles")
}

model Employee {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String
  cpf           String
  role          String // porteiro, zelador, jardineiro, etc.
  phone         String?
  email         String?
  shift         ShiftType
  admissionDate DateTime
  salaryAmount  Decimal?    @db.Decimal(10, 2)
  isActive      Boolean     @default(true)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Vínculo opcional com conta de acesso ao sistema
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique

  @@map("employees")
}

model ServiceProvider {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String
  cnpj          String?
  cpf           String?
  serviceType   String // encanador, eletricista, pintor, etc.
  phone         String
  email         String?
  photoUrl      String?
  isApproved    Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  visitors      Visitor[]
  serviceOrders ServiceOrder[]
  contracts     Contract[]

  @@map("service_providers")
}

// ─────────────────────────────────────────────────────────────
// PORTARIA E CONTROLE DE ACESSO
// ─────────────────────────────────────────────────────────────

model Visitor {
  id              String        @id @default(uuid())
  unit            Unit          @relation("UnitVisitors", fields: [unitId], references: [id])
  unitId          String
  name            String
  document        String?
  documentType    String? // CPF, RG, CNH
  phone           String?
  photoUrl        String?
  company         String?
  reason          String?
  preAuthorizedBy String? // ID do morador que autorizou
  status          VisitorStatus @default(PENDING)
  scheduledAt     DateTime?
  entryAt         DateTime?
  exitAt          DateTime?
  registeredBy    String? // ID do porteiro
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?

  @@map("visitors")
}

model VehicleAccessLog {
  id           String    @id @default(uuid())
  vehicle      Vehicle?  @relation(fields: [vehicleId], references: [id])
  vehicleId    String?
  plate        String // mesmo para não cadastrados
  unitId       String?
  isResident   Boolean   @default(false)
  entryAt      DateTime  @default(now())
  exitAt       DateTime?
  notes        String?
  registeredBy String?

  @@index([entryAt])
  @@index([plate])
  @@map("vehicle_access_logs")
}

model Parcel {
  id                 String       @id @default(uuid())
  unit               Unit         @relation(fields: [unitId], references: [id])
  unitId             String
  senderName         String?
  carrier            String?
  trackingCode       String?
  photoUrl           String?
  storageLocation    String?
  // Dados do entregador (Lei 11.442/07 + LGPD Art. 7º IX)
  deliveryPersonName String? // Nome completo do entregador
  deliveryPersonDoc  String? // CPF ou RG (apenas números)
  vehiclePlate       String? // Placa do veículo (RNTRC/ANTT)
  // Controle de avaria (Art. 754 Código Civil)
  hasPackageDamage   Boolean      @default(false)
  status             ParcelStatus @default(RECEIVED)
  receivedAt         DateTime     @default(now())
  notifiedAt         DateTime?
  pickedUpAt         DateTime?
  pickedUpBy         String? // nome de quem retirou
  pickupSignature    String? // assinatura digital ou PIN
  notes              String?
  registeredBy       String?

  @@index([unitId, status, receivedAt])
  @@map("parcels")
}

// ─────────────────────────────────────────────────────────────
// COMUNICAÇÃO
// ─────────────────────────────────────────────────────────────

model Announcement {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  title         String
  content       String
  authorId      String
  isPinned      Boolean     @default(false)
  isOfficial    Boolean     @default(false)
  attachments   String[]
  targetRoles   UserRole[]
  publishedAt   DateTime    @default(now())
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("announcements")
}

model Notification {
  id            String           @id @default(uuid())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  condominium   Condominium?     @relation(fields: [condominiumId], references: [id])
  condominiumId String?
  type          NotificationType
  title         String
  message       String
  data          Json?
  referenceId   String?
  referenceType String?
  isRead        Boolean          @default(false)
  readAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([userId, isRead])
  @@index([condominiumId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String           @id @default(uuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  inapp     Boolean          @default(true)
  email     Boolean          @default(true)
  push      Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

model ChatConversation {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  unitId        String?
  subject       String?
  participants  String[] // array de userIds
  isOpen        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  messages ChatMessage[]

  @@index([condominiumId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])
  conversationId String
  sender         User             @relation("SentMessages", fields: [senderId], references: [id])
  senderId       String
  content        String
  attachments    String[]
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@map("chat_messages")
}

model Poll {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  title         String
  description   String?
  options       Json // [{id, text, votes}]
  allowMultiple Boolean     @default(false)
  isAnonymous   Boolean     @default(false)
  startsAt      DateTime    @default(now())
  endsAt        DateTime
  createdBy     String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id        String   @id @default(uuid())
  poll      Poll     @relation(fields: [pollId], references: [id])
  pollId    String
  userId    String
  optionIds String[] // opções escolhidas
  votedAt   DateTime @default(now())

  @@unique([pollId, userId])
  @@map("poll_votes")
}

model Occurrence {
  id            String               @id @default(uuid())
  condominium   Condominium          @relation(fields: [condominiumId], references: [id])
  condominiumId String
  reportedBy    String
  title         String
  description   String
  category      String // segurança, barulho, vandalismo, etc.
  location      String?
  photoUrls     String[]
  status        OccurrenceStatus     @default(OPEN)
  priority      ServiceOrderPriority @default(MEDIUM)
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("occurrences")
}

// ─────────────────────────────────────────────────────────────
// FINANCEIRO
// ─────────────────────────────────────────────────────────────

model FinancialAccount {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String // Conta principal, fundo reserva, etc.
  bankName      String?
  agency        String?
  accountNumber String?
  // Coluna `balance` removida (era stored mas nunca atualizada na
  // escrita — getAccountBalance recalcula via aggregate). Mantê-la
  // teria sido armadilha: race entre transactions concorrentes
  // faria balance divergir. Source-of-truth: aggregate sob demanda.
  isActive      Boolean     @default(true)

  // Gateway config
  gatewayType      GatewayType @default(NONE)
  // Plaintext legado — ainda lido durante a fase EXPAND da migração
  // de criptografia. Será DROPado em CONTRACT (Sprint seguinte).
  gatewayKey       String? // API Key or Token (LEGADO PLAINTEXT)
  gatewayConfig    Json? // walletId, common settings (LEGADO PLAINTEXT)
  // Cifrados via cryptoVault (AES-256-GCM, formato v1.iv.tag.ct).
  // Source-of-truth a partir do CONTRACT.
  gatewayKeyEnc    String?
  gatewayConfigEnc String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FinancialTransaction[]
  charges      Charge[]

  @@map("financial_accounts")
}

model FinancialCategory {
  id            String                   @id @default(uuid())
  condominium   Condominium              @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String
  type          FinancialTransactionType
  description   String?
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())

  transactions FinancialTransaction[]
  charges      Charge[]

  @@index([condominiumId])
  @@map("financial_categories")
}

model FinancialTransaction {
  id             String                   @id @default(uuid())
  account        FinancialAccount         @relation(fields: [accountId], references: [id])
  accountId      String
  category       FinancialCategory?       @relation(fields: [categoryId], references: [id])
  categoryId     String?
  type           FinancialTransactionType
  amount         Decimal                  @db.Decimal(12, 2)
  description    String
  dueDate        DateTime
  paidAt         DateTime?
  referenceMonth String? // "2025-01"
  receiptUrl     String?
  notes          String?
  createdBy      String
  chargeId       String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([accountId, type, paidAt])
  @@index([accountId, referenceMonth, type])
  @@map("financial_transactions")
}

// Outbox de webhooks externos.
// Webhook handler grava o evento atomicamente (UNIQUE em
// provider+externalId garante idempotência da entrega). O
// PROCESSAMENTO real (charge.update, fin_tx.create) é feito por
// um BullMQ worker separado (webhookProcessor) que lê rows com
// processedAt IS NULL, processa em $transaction e seta
// processedAt. Resiliente a falha do DB durante processamento:
// row fica pendente, próximo pickup faz retry.
//
// processingError captura a última mensagem de erro para
// triagem (não é histórico — sobrescrita a cada attempt).
//
// attempts limita reprocessamento; ao atingir o teto, row é
// movida para processedAt manualmente após investigação ou
// permanece pendente para alerta operacional.
model WebhookEvent {
  id              String    @id @default(uuid())
  provider        String // "asaas", "pjbank", etc.
  externalId      String // event id do provider, ou paymentId+eventType
  eventType       String
  payload         Json
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  processingError String?
  attempts        Int       @default(0)

  @@unique([provider, externalId])
  @@index([provider, receivedAt])
  @@index([provider, processedAt])
  @@map("webhook_events")
}

model Charge {
  id             String             @id @default(uuid())
  unit           Unit               @relation(fields: [unitId], references: [id])
  unitId         String
  account        FinancialAccount   @relation(fields: [accountId], references: [id])
  accountId      String
  category       FinancialCategory? @relation(fields: [categoryId], references: [id])
  categoryId     String?
  description    String
  amount         Decimal            @db.Decimal(12, 2)
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Decimal?           @db.Decimal(12, 2)
  status         ChargeStatus       @default(PENDING)
  referenceMonth String?

  // Gateway metadata
  gatewayId     String?
  gatewayStatus String?
  pixQrCode     String? @db.Text
  pixCopyPaste  String? @db.Text
  paymentLink   String? @db.Text

  boletoUrl     String?
  boletoCode    String?
  penaltyAmount Decimal  @default(0) @db.Decimal(12, 2)
  interestRate  Decimal  @default(0) @db.Decimal(5, 4) // % a.m.
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([gatewayId])
  @@index([unitId, status, dueDate])
  @@index([status, dueDate])
  @@map("charges")
}

// ─────────────────────────────────────────────────────────────
// MANUTENÇÃO
// ─────────────────────────────────────────────────────────────

model ServiceOrder {
  id                String               @id @default(uuid())
  unit              Unit?                @relation(fields: [unitId], references: [id])
  unitId            String?
  condominium       Condominium          @relation(fields: [condominiumId], references: [id])
  condominiumId     String
  requestedBy       String
  assignedTo        String?
  serviceProvider   ServiceProvider?     @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?
  title             String
  description       String
  category          String // elétrica, hidráulica, limpeza, etc.
  location          String?
  priority          ServiceOrderPriority @default(MEDIUM)
  status            ServiceOrderStatus   @default(OPEN)
  photoUrls         String[]
  estimatedCost     Decimal?             @db.Decimal(10, 2)
  finalCost         Decimal?             @db.Decimal(10, 2)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  resolution        String?
  rating            Int? // 1-5
  feedback          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  checklistItems ServiceOrderChecklist[]

  @@index([condominiumId, status, createdAt])
