  visitorDoc   String?
  visitorPhone String?
  reason       String?
  validFrom    DateTime
  validUntil   DateTime
  maxUses      Int            @default(1)
  usedCount    Int            @default(0)
  token        String         @unique @default(uuid())
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())

  uses         VisitorQRUse[]

  @@map("visitor_qrcodes")
}

model VisitorQRUse {
