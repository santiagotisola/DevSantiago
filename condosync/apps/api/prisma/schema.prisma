  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  title         String
  description   String?
  category      String // areas-comuns, eventos, obras, outro
  fileName      String
  storedName    String
  filePath      String
  fileSize      Int
  mimeType      String
  uploadedBy    String
  createdAt     DateTime    @default(now())

  @@index([condominiumId])
  @@map("photos")
}

// ─── Marketplace / Clube de Benefícios ── MEL-18 ─────────────────────────────

enum MarketplaceOfferStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum VisibilityMode {
  LOCAL // Visível apenas no condomínio que criou
  GLOBAL // Visível em múltiplos condominiums
  SELECTIVE // Escolher quais condominiums
}

enum MarketplaceProductRequestStatus {
  PENDING // Requisição criada, aguardando resposta
  QUOTED // Parceiro respondeu com orçamento
  ACCEPTED // Morador aceitou a oferta
  REJECTED // Morador rejeitou
  DELIVERED // Entregue
  CANCELLED // Cancelado
}

enum CustomerTier {
  BRONZE // 0-1000 pontos
  SILVER // 1001-5000 pontos
  GOLD // 5001+ pontos
}

model MarketplacePartner {
  id          String  @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  website     String?
  phone       String?
  email       String?
  category    String // alimentacao, saude, educacao, servicos, lazer, outro

  // NOVO: Controle de visibilidade global
  visibilityMode         VisibilityMode @default(LOCAL)
  createdByCondominiumId String? // Qual condomínio criou (null = sistema)

  // Ativas
  isActive    Boolean @default(true)
  rating      Float   @default(0)
  reviewCount Int     @default(0)
  isVerified  Boolean @default(false)

  // Para compatibilidade com código antigo - deprecated em v2
  condominiumId String?
  condominium   Condominium? @relation(name: "PartnerToCondominium", fields: [condominiumId], references: [id], onDelete: Cascade)

  // Relações
  condominiums    CondominiumMarketplacePartner[]
  products        MarketplaceProduct[]
  offers          MarketplaceOffer[]
  requests        MarketplaceProductRequest[]
  reviews         MarketplaceProductReview[]
  purchaseHistory PurchaseHistory[]               @relation("PurchaseHistoryPartner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketplace_partners")
}

// NOVO: Tabela de junção para visibilidade em múltiplos condominiums
model CondominiumMarketplacePartner {
  id            String             @id @default(uuid())
  partner       MarketplacePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId     String
  condominium   Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String

  // Informações específicas por filial
  branchName   String? // ex: "Academia FitLife - Zona Sul"
  branchPhone  String?
  branchEmail  String?
  deliveryZone String? // ex: "Raio 5km"

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partnerId, condominiumId])
  @@map("condominium_marketplace_partners")
}

// NOVO: Produtos do Catálogo
model MarketplaceProduct {
  id            String             @id @default(uuid())
  partner       MarketplacePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId     String
  condominium   Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String

  name         String
  description  String?
  price        Decimal @db.Decimal(10, 2)
  discount     Decimal @default(0) @db.Decimal(5, 2) // percentual
  finalPrice   Decimal @db.Decimal(10, 2) // preço após desconto
  shippingCost Decimal @default(0) @db.Decimal(10, 2)

  imageUrl String?
  category String? // subcategoria do produto
  stock    Int     @default(-1) // -1 = ilimitado

  rating      Float @default(0)
  reviewCount Int   @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  images    MarketplaceProductImage[]
  requests  MarketplaceProductRequest[]
  reviews   MarketplaceProductReview[]
  favorites ResidentFavorite[]

  @@index([partnerId])
  @@index([condominiumId])
  @@map("marketplace_products")
}

// NOVO: Múltiplas imagens por produto
model MarketplaceProductImage {
  id           String             @id @default(uuid())
  product      MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  imageUrl     String
  displayOrder Int                @default(0)
  createdAt    DateTime           @default(now())

  @@map("marketplace_product_images")
}

// NOVO: Requisições de Moradores por Produtos
model MarketplaceProductRequest {
  id            String             @id @default(uuid())
  product       MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String
  partner       MarketplacePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId     String
  resident      User               @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId    String
  condominium   Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String

  quantity Int                             @default(1)
  notes    String?
  status   MarketplaceProductRequestStatus @default(PENDING)

  // Orçamento do parceiro
  quotedPrice Decimal?  @db.Decimal(10, 2)
  quotedAt    DateTime?

  // Timeline
  requestedAt  DateTime  @default(now())
  respondedAt  DateTime?
  acceptedAt   DateTime?
  deliveryDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  messages MarketplaceChatMessage[]

  @@index([partnerId])
  @@index([residentId])
  @@index([condominiumId])
  @@map("marketplace_product_requests")
}

// NOVO: Chat em tempo real
model MarketplaceChatMessage {
  id        String                    @id @default(uuid())
  request   MarketplaceProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String
  sender    User                      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId  String

  message       String
  isFromPartner Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([requestId])
  @@map("marketplace_chat_messages")
}

// NOVO: Avaliações de Produtos
model MarketplaceProductReview {
  id         String             @id @default(uuid())
  product    MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  partner    MarketplacePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId  String
  resident   User               @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId String

  rating  Int     @default(5) // 1-5
  comment String?
  images  String? // JSON array de URLs

  isVerified Boolean  @default(true) // Morador realmente comprou
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, residentId])
  @@map("marketplace_product_reviews")
}

// NOVO: Favoritos do Residente
model ResidentFavorite {
  id         String             @id @default(uuid())
  resident   User               @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId String
  product    MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String

  savedAt DateTime @default(now())

  @@unique([residentId, productId])
  @@map("resident_favorites")
}

// NOVO: Sistema de Pontos e Fidelidade
model LoyaltyPoints {
  id         String @id @default(uuid())
  resident   User   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId String @unique

  points Int          @default(0)
  tier   CustomerTier @default(BRONZE)

  totalSpent     Decimal @default(0) @db.Decimal(12, 2)
  totalPurchases Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loyalty_points")
}

// NOVO: Histórico de Compras
model PurchaseHistory {
  id            String             @id @default(uuid())
  resident      User               @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId    String
  partner       MarketplacePartner @relation("PurchaseHistoryPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId     String
  condominium   Condominium        @relation("PurchaseHistoryCondominium", fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String

  productName String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  discount    Decimal @db.Decimal(5, 2)
  finalPrice  Decimal @db.Decimal(10, 2)

  pointsEarned Int @default(0)

  purchasedAt DateTime @default(now())

  @@index([residentId])
  @@index([partnerId])
  @@map("purchase_history")
}

// Atualizando modelo User para adicionar relações novas
// (veremos isso depois, por enquanto apenas comentado)

model MarketplaceOffer {
  id            String                 @id @default(uuid())
  // Opcional: offer pode ser global (gerida por SUPER_ADMIN) ou escopada a um condomínio.
  condominium   Condominium?           @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String?
  partner       MarketplacePartner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId     String
  title         String
  description   String
  discount      String?
  couponCode    String?
  validUntil    DateTime?
  status        MarketplaceOfferStatus @default(ACTIVE)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@map("marketplace_offers")
}

// NOVO: Categorias customizáveis por condomínio
model MarketplaceCategory {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String

  name         String // ex: "Alimentação", "Saúde"
  label        String? // ex: "Alimentação e Bebidas" (exibição)
  slug         String // ex: "alimentacao" (identificador único)
  description  String? // ex: "Produtos e serviços de alimentação"
  icon         String? // ex: "🍔" ou "utensils" (Lucide icon)
  color        String? // ex: "#FF6B6B" (cor da categoria)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([condominiumId, slug])
  @@index([condominiumId])
  @@map("marketplace_categories")
}

// ─── Ofertas ───────────────────────────────────────────────────
// ─── Botão de Pânico ── MEL-19 ────────────────────────────────────────────────
model PanicAlert {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  triggeredBy   String // userId
  resolvedBy    String? // userId
  resolvedAt    DateTime?
  notes         String?
  createdAt     DateTime    @default(now())

  @@map("panic_alerts")
}

// ─── Visitantes Recorrentes ────────────────────────────────────────────────────
model VisitorRecurrence {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  unit          Unit        @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitId        String
  visitorName   String
  document      String?
  documentType  String? // CPF, RG, CNH, PASSPORT
  company       String?
  reason        String?
  weekDays      String[] // MON, TUE, WED, THU, FRI, SAT, SUN
  startTime     String // HH:MM
  endTime       String // HH:MM
  validFrom     DateTime
  validUntil    DateTime?
  isActive      Boolean     @default(true)
  createdBy     String // userId
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("visitor_recurrences")
}

// ─────────────────────────────────────────────────────────────
// QR CODE DE VISITANTE
// ─────────────────────────────────────────────────────────────

model VisitorQRCode {
  id           String   @id @default(uuid())
  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId       String
  createdBy    String // userId do morador
  visitorName  String
  visitorDoc   String?
  visitorPhone String?
  reason       String?
  validFrom    DateTime
  validUntil   DateTime
  maxUses      Int      @default(1)
  usedCount    Int      @default(0)
  token        String   @unique @default(uuid())
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  uses VisitorQRUse[]

  @@map("visitor_qrcodes")
}

model VisitorQRUse {
  id        String        @id @default(uuid())
  qrcode    VisitorQRCode @relation(fields: [qrcodeId], references: [id], onDelete: Cascade)
  qrcodeId  String
  visitorId String? // Visitor criado ao escanear (opcional)
  scannedAt DateTime      @default(now())
  scannedBy String // userId do porteiro

  @@map("visitor_qrcode_uses")
}

// ─────────────────────────────────────────────────────────────
// CONTRATOS CONDOMINIAIS (independente de prestador cadastrado)
// ─────────────────────────────────────────────────────────────

model CondominiumContract {
  id              String      @id @default(uuid())
  condominium     Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId   String
  title           String // "Contrato Elevador Atlas 2026"
  vendor          String // nome da empresa contratada
  contractType    String // ELEVATOR | INSURANCE | CLEANING | SECURITY | MAINTENANCE | OTHER
  startDate       DateTime
  endDate         DateTime
  value           Decimal     @db.Decimal(12, 2)
  adjustmentIndex String? // INPC | IGPM | IPCA
  fileUrl         String?
  notes           String?
  autoRenew       Boolean     @default(false)
  alertDaysBefore Int         @default(60) // alertar N dias antes do vencimento
  status          String      @default("ACTIVE") // ACTIVE | EXPIRED | CANCELED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([condominiumId])
  @@map("condominium_contracts")
}

// ─────────────────────────────────────────────────────────────
// SISTEMA DE MULTAS CONDOMINIAIS
// ─────────────────────────────────────────────────────────────

model Fine {
  id             String      @id @default(uuid())
  condominium    Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId  String
  unitId         String
  reportedBy     String // userId do síndico/admin
  description    String
  regulation     String // artigo do regimento/convenção
  photoUrls      String[]
  amount         Decimal     @db.Decimal(10, 2)
  appealDeadline DateTime // prazo para recurso (padrão 15 dias)
  appealText     String? // recurso enviado pelo morador
  appealedAt     DateTime?
  appealStatus   String? // ACCEPTED | REJECTED
  appealResponse String? // resposta do síndico
  status         String      @default("PENDING") // PENDING | APPEAL | CONFIRMED | CANCELED | CONVERTED
  chargeId       String? // cobrança gerada após confirmação (ASAAS)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([condominiumId, status, createdAt])
  @@index([unitId])
  @@map("fines")
}

// ─────────────────────────────────────────────────────────────
// RÉGUA DE COBRANÇA AUTOMÁTICA
// ─────────────────────────────────────────────────────────────

model CollectionRule {
  id            String           @id @default(uuid())
  condominium   Condominium      @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String // "Régua Padrão 2026"
  isActive      Boolean          @default(true)
  steps         CollectionStep[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([condominiumId, isActive])
  @@map("collection_rules")
}

model CollectionStep {
  id              String         @id @default(uuid())
  rule            CollectionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId          String
  daysAfterDue    Int // D+1, D+7, D+30, D+60
  channels        String[] // ["email","inapp"]
  messageTemplate String // "Olá {{nome}}, sua cota venceu. Valor: R$ {{valor}}"
  action          String         @default("notify") // notify | block_amenities

  @@map("collection_steps")
}

// ─────────────────────────────────────────────────────────────
// DIGITAL SIGNAGE — TV/MONITOR ELEVADOR
// ─────────────────────────────────────────────────────────────

model DigitalSignageScreen {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String // "Elevador Torre A", "Hall Social"
  location      String // localização física
  token         String      @unique @default(uuid())
  isActive      Boolean     @default(true)
  slideDuration Int         @default(8) // segundos por slide (padrão)
  primaryColor  String      @default("#1e40af") // cor tema da tela
  logoUrl       String? // logo do condomínio na tela
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  slides DigitalSignageSlide[]

  @@index([condominiumId])
  @@map("digital_signage_screens")
}

model DigitalSignageSlide {
  id              String               @id @default(uuid())
  screen          DigitalSignageScreen @relation(fields: [screenId], references: [id], onDelete: Cascade)
  screenId        String
  type            String // TEXT | IMAGE | ANNOUNCEMENT | BIRTHDAY | CLOCK | MARKETPLACE
  title           String?
  content         String?
  imageUrl        String?
  backgroundColor String? // hex color ex: "#0f172a"
  textColor       String? // hex color ex: "#ffffff"
  order           Int                  @default(0)
  duration        Int? // segundos (sobrescreve padrão da tela)
  isActive        Boolean              @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("digital_signage_slides")
}

// ─────────────────────────────────────────────────────────────
// PLANOS DE ASSINATURA (SUPER_ADMIN)
// ─────────────────────────────────────────────────────────────
// Condominium.plan armazena o `slug` deste model (relação fraca,
// sem FK, pra não exigir migration do Condominium). maxUnits do
// condomínio pode ser sobrescrito (override) por SUPER_ADMIN.
model Plan {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  price       Decimal  @default(0) @db.Decimal(10, 2)
  maxUnits    Int      @default(100)
  features    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────
// CONVITES DE MORADOR / USUÁRIO
// ─────────────────────────────────────────────────────────────
// Síndico/admin cria convite com token de uso único. Morador recebe
// link por email e define a própria senha. Quando aceito, cria User
// (se não existir pelo email/CPF) e vincula via CondominiumUser.
model Invitation {
  id            String      @id @default(uuid())
  tokenHash     String      @unique // sha256 do token; o token plain só viaja no email
  email         String
  name          String?
  cpf           String?
  phone         String?
  role          UserRole
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  condominiumId String
  unit          Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitId        String? // obrigatório para RESIDENT
  invitedById   String
  invitedBy     User        @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedById  String?
  acceptedBy    User?       @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  expiresAt     DateTime
  acceptedAt    DateTime?
  revokedAt     DateTime?
  lastSentAt    DateTime    @default(now())
  sendCount     Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([email])
  @@index([condominiumId])
  @@index([expiresAt])
  @@map("invitations")
}

// ─────────────────────────────────────────────────────────────
// PUSH NOTIFICATIONS (Web Push / VAPID)
// ─────────────────────────────────────────────────────────────
model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String // chave pública do cliente
  auth       String // segredo de autenticação do cliente
  userAgent  String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// WEBAUTHN / BIOMETRIA (passkeys)
// ─────────────────────────────────────────────────────────────
model WebAuthnCredential {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique // base64url do credential id retornado pelo authenticator
  publicKey    Bytes
  counter      Int       @default(0)
  transports   String[] // ex: ["internal", "hybrid"]
  deviceName   String? // rótulo amigável definido pelo usuário
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("webauthn_credentials")
}

// ─────────────────────────────────────────────────────────────
// LGPD — termos versionados + aceite + audit trail
// ─────────────────────────────────────────────────────────────
model TermsVersion {
  id          String   @id @default(uuid())
  kind        String // "terms_of_use" | "privacy_policy"
  version     String // ex: "1.0.0", "2026-05-12"
  contentMd   String // markdown
  effectiveAt DateTime @default(now())
  createdBy   String? // userId
  createdAt   DateTime @default(now())

  acceptances TermsAcceptance[]

  @@unique([kind, version])
  @@index([kind, effectiveAt])
  @@map("terms_versions")
}

model TermsAcceptance {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  termsVersion   TermsVersion @relation(fields: [termsVersionId], references: [id], onDelete: Restrict)
  termsVersionId String
  acceptedAt     DateTime     @default(now())
  ipAddress      String?
  userAgent      String?

  @@unique([userId, termsVersionId])
  @@index([userId])
  @@map("terms_acceptances")
}

// ─────────────────────────────────────────────────────────────
// AGENDA DE MUDANÇA
// ─────────────────────────────────────────────────────────────

enum MovingType {
  MOVE_IN
  MOVE_OUT
  LARGE_DELIVERY
}

enum MovingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELED
}

model MovingSchedule {
  id               String       @id @default(uuid())
  condominium      Condominium  @relation(fields: [condominiumId], references: [id])
  condominiumId    String
  unit             Unit         @relation(fields: [unitId], references: [id])
  unitId           String
  type             MovingType
  scheduledDate    DateTime
  startTime        String // "08:00"
  endTime          String // "12:00"
  elevator         String? // "Social", "Serviço"
  responsibleName  String
  responsiblePhone String?
  companyName      String? // Nome da empresa de mudança
  notes            String?
  status           MovingStatus @default(PENDING)
  approvedBy       String?
  rejectedReason   String?
  createdBy        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("moving_schedules")
}

// ─────────────────────────────────────────────────────────────
// CONTROLE DE CHAVES
// ─────────────────────────────────────────────────────────────

enum KeyStatus {
  AVAILABLE
  BORROWED
  LOST
  MAINTENANCE
}

model KeyControl {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  keyIdentifier String // "Chave Salão 01", "Portão Garagem B"
  description   String?
  location      String? // Onde fica guardada
  status        KeyStatus   @default(AVAILABLE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  logs KeyControlLog[]

  @@map("key_controls")
}

model KeyControlLog {
  id             String     @id @default(uuid())
  key            KeyControl @relation(fields: [keyId], references: [id], onDelete: Cascade)
  keyId          String
  action         String // "BORROW", "RETURN", "LOST", "FOUND"
  borrowedBy     String? // Nome de quem pegou
  borrowedByUnit String? // Unidade
  receivedBy     String? // Porteiro que entregou/recebeu
  notes          String?
  createdAt      DateTime   @default(now())

  @@map("key_control_logs")
}

model Camera {
  id            String      @id @default(uuid())
  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  condominiumId String
  name          String // "Câmera Entrada Principal"
  location      String // "Portaria", "Garagem B1"
  brand         String? // "Intelbras", "Hikvision"
  model         String? // "VIP 1230"
  streamUrl     String // URL do stream HLS/RTSP
  embedUrl      String? // URL para embed iframe (plataformas cloud)
  snapshotUrl   String? // URL para snapshot/thumbnail
  isActive      Boolean     @default(true)
  isRecording   Boolean     @default(false)
  resolution    String? // "1080p", "4K"
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("cameras")
}
