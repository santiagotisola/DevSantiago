  ticketId  String
  senderId  String
  sender    User     @relation("TicketMessages", fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

// ─── Galeria de Fotos ── MEL-10 ───────────────────────────────────────────────

model Photo {
