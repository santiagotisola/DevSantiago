  @@map("stock_movements")
}

// ─── Tickets / Mensagens individuais ── MEL-06 ────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketCategory {
  manutencao
  financeiro
  barulho
  seguranca
  outro
}

model Ticket {
