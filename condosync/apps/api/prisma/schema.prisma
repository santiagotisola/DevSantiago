// ─── Tickets / Mensagens individuais ── MEL-06 ────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketCategory {
  manutencao
  financeiro
  barulho
  seguranca
  outro
}

model Ticket {
  id            String          @id @default(uuid())
