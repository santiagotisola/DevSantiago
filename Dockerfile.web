# Dockerfile para o serviço Web no Railway (contexto = raiz do repositório)
# ─── Stage 1: Builder ─────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

COPY condosync/apps/web/package.json ./

RUN npm install

COPY condosync/apps/web/ ./

RUN npm run build

# ─── Stage 2: Production (nginx) ──────────────────────────────────────────────
FROM nginx:1.27-alpine AS production

RUN rm /etc/nginx/conf.d/default.conf

# O nginx:1.27-alpine roda envsubst automaticamente em /etc/nginx/templates/*.template
COPY condosync/apps/web/nginx.conf.template /etc/nginx/templates/default.conf.template

COPY --from=builder /app/dist /usr/share/nginx/html

# Fallback para API_URL — substituído pela env var do Railway se definida
ENV API_URL=https://devsantiago-production.up.railway.app

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
