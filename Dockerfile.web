# Dockerfile para o serviço Web no Railway (contexto = raiz do repositório)
# ─── Stage 1: Builder ─────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY condosync/package*.json ./
COPY condosync/apps/web/package*.json ./apps/web/

RUN npm install

COPY condosync/apps/web/ ./apps/web/

WORKDIR /app/apps/web

RUN npx vite build

# ─── Stage 2: Production (nginx) ──────────────────────────────────────────────
FROM nginx:1.25-alpine AS production

RUN rm /etc/nginx/conf.d/default.conf

COPY condosync/apps/web/nginx.conf /etc/nginx/conf.d/default.conf

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

EXPOSE 80

CMD ["/bin/sh", "-c", "envsubst '${API_URL}' < /etc/nginx/conf.d/default.conf > /tmp/default.conf && mv /tmp/default.conf /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
